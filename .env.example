# 飞书自建应用凭证
# 请从「飞书开放平台 -> 凭证与基础信息」获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书多维表格信息
# bitable_app_token: 多维表格 URL 中的 app_token 片段
# table_id: 数据表 ID
FEISHU_BITABLE_APP_TOKEN=xxxxxxxxxxxxxxxx
FEISHU_TABLE_ID=xxxxxxxxxxxxxxxx

# 可选：租户访问令牌
# 留空时服务会自动通过 app_id/app_secret 获取
FEISHU_TENANT_ACCESS_TOKEN=

# 服务端口号（本地开发）
PORT=3000
